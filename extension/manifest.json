{
  "manifest_version": 3,
  "name": "Blackboard Student Assistant",
  "version": "1.1.0",
  "key": "",
  "description": "Scans your college Blackboard for deadlines, grades, and schedules. Provides deadline notifications, grade calculations, Google Calendar integration, and personalized study plans.",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "identity",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "https://*.blackboard.com/*",
    "https://elearning.utdallas.edu/*",
    "https://*.instructure.com/*",
    "https://www.googleapis.com/*",
    "https://accounts.google.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "oauth2": {
    "client_id": "402746486610-2ljvcdl6k76s0q4339vm00fbci4j9s61.apps.googleusercontent.com",
    "scopes": [
        "https://www.googleapis.com/auth/calendar.events"
    ]
  },
  "background": {
    "service_worker": "js/background.js"
  },
  "action": {
    "default_popup": "pages/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.blackboard.com/*",
        "https://elearning.utdallas.edu/*",
        "https://*.instructure.com/*"
      ],
      "js": ["js/content-script.js"],
      "css": ["css/content-overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "pages/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["vendor/pdf.worker.min.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
